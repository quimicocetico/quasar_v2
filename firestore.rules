rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── FUNÇÕES AUXILIARES ───────────────────────────────────────
    function isAutenticado() {
      return request.auth != null;
    }
    function isProfessor() {
      return isAutenticado() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.papel == 'professor';
    }
    function isAluno() {
      return isAutenticado() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.papel == 'aluno';
    }

    // ─── USUÁRIOS ────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAutenticado();
      allow write: if isAutenticado() && (request.auth.uid == uid || isProfessor());
    }
    match /users {
      allow read, list: if isAutenticado();
    }

    // ─── ESCOLAS E TURMAS ────────────────────────────────────────
    match /escolas/{escolaId} {
      allow read: if true; 
      allow create: if isProfessor();
      allow update, delete: if isProfessor() && (
        resource.data.professor_uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.id == resource.data.professor_uid
      );
      
      match /turmas/{turmaId} {
        allow read: if true;
        allow create: if isProfessor();
        allow update, delete: if isProfessor() && (
          request.auth.uid in resource.data.professores || 
          get(/databases/$(database)/documents/escolas/$(escolaId)).data.professor_uid == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['professores'])
        );
      }
    }

    // ─── MATRÍCULAS ──────────────────────────────────────────────
    match /matriculas/{matriculaId} {
      allow read: if isAutenticado();
      allow create, delete: if isProfessor();
      allow update: if isProfessor() || (
        isAutenticado() && 
        request.auth.token.email.lower() == resource.data.email.lower() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aluno_uid'])
      );
    }

    // ─── TAÇA DAS CASAS ──────────────────────────────────────────
    match /taca_casas/{temporadaId} {
      allow read: if true;
      
      match /casas/{casaId} {
        allow read: if true;
        allow write: if isProfessor();
      }
      
      match /eventos/{eventoId} {
        allow read: if true;
        allow create: if isProfessor();
        allow update, delete: if false;
      }
    }

    // =====================================================================
    // FERRAMENTA: INICIAÇÃO CIENTÍFICA (Gestão de Projetos)
    // =====================================================================
    
    match /projetos/{projetoId} {
      // 1. LEITURA DO PROJETO
      // 'get' permite ler se souber o ID exato (Link Mágico). 'list' é bloqueado para visitantes.
      allow get: if true; 
      allow list: if isAutenticado() && (
        request.auth.uid == resource.data.dados_gerais.professorId || 
        request.auth.token.email in resource.data.membros_emails
      );

      // 2. CRIAÇÃO E ATUALIZAÇÃO DO PROJETO
      allow create: if isProfessor() && request.resource.data.dados_gerais.professorId == request.auth.uid;
      allow update: if isAutenticado() && (
        request.auth.uid == resource.data.dados_gerais.professorId || // Professor dono pode atualizar tudo
        // Aluno convidado só pode atualizar para aceitar o convite
        request.auth.token.email in resource.data.membros_emails 
      );

      // -------------------------------------------------------------------
      // SUBCOLEÇÃO: ETAPAS
      // -------------------------------------------------------------------
      match /etapas/{etapaId} {
        // Leitura segue a mesma lógica do projeto principal
        allow read: if true; // Protegido pelo ID do projeto e da etapa
        allow write: if isAutenticado() && (
          get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.professorId == request.auth.uid ||
          request.auth.token.email in get(/databases/$(database)/documents/projetos/$(projetoId)).data.membros_emails
        );

        // -----------------------------------------------------------------
        // SUBCOLEÇÃO: SUBMISSÕES (Diário de Bordo - Imutável)
        // -----------------------------------------------------------------
        match /submissoes/{submissaoId} {
          allow read: if true;
          allow create: if isAutenticado() && (
            request.auth.token.email in get(/databases/$(database)/documents/projetos/$(projetoId)).data.membros_emails ||
            get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.professorId == request.auth.uid
          );
          allow update, delete: if false; 

          match /feedbacks/{feedbackId} {
            allow read: if true;
            allow create: if isAutenticado() && (
              request.auth.token.email in get(/databases/$(database)/documents/projetos/$(projetoId)).data.membros_emails ||
              get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.professorId == request.auth.uid
            ) || (request.resource.data.token == get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.token_coorientador);
            allow update, delete: if false;
          }
        }

        match /feedbacks/{feedbackId} {
          allow read: if true;
          allow create: if isAutenticado() && (
            request.auth.token.email in get(/databases/$(database)/documents/projetos/$(projetoId)).data.membros_emails ||
            get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.professorId == request.auth.uid
          ) || (request.resource.data.token == get(/databases/$(database)/documents/projetos/$(projetoId)).data.dados_gerais.token_coorientador);
          allow update, delete: if false;
        }
      }
    }

    // ─── COLLECTION GROUPS ───────────────────────────────────────
    match /{path=**}/eventos/{eventoId} {
      allow read: if true;
    }
  }
}
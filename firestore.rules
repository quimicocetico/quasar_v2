rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── FUNÇÕES AUXILIARES ──────────────────────────────────────────

    function isAutenticado() {
      return request.auth != null;
    }

    function isAluno() {
      return isAutenticado() &&
        request.auth.token.email.matches('.*@estudante[.]rn[.]gov[.]br');
    }

    function isProfessor() {
      return isAutenticado() &&
        request.auth.token.email.matches('.*@educar[.]rn[.]gov[.]br');
    }

    function isInstitucional() {
      return isAluno() || isProfessor();
    }

    function isDonoDaAula() {
      return isProfessor() &&
        request.auth.token.email == resource.data.professor_email;
    }

    function isDonoDaAulaEscrita() {
      return isProfessor() &&
        request.auth.token.email == request.resource.data.professor_email;
    }



    // ─── OBJETOS EDUCACIONAIS ───────────────────────────────────────

    // Desafios (Timeline, Quizzes, etc)
    match /challenges/{challengeId} {
      allow read: if isAutenticado();
      allow write: if isProfessor();
      
      // Subcoleção de scores (se usada)
      match /scores/{scoreId} {
        allow read: if isAutenticado();
        allow write: if isAutenticado();
      }
    }

    // Configurações Globais (Ativação de desafios)
    match /config/{configId} {
      allow read: if isAutenticado();
      allow write: if isProfessor();
    }

    // Sessões de Jogo e Ranking em Tempo Real
    match /sessoes_timeline/{sessionId} {
      allow read: if isAutenticado();
      allow write: if isAutenticado();
    }

  }
}